---
import { projects, constellationEdges, getProject } from '../data/projects';

const edges = constellationEdges
  .map(([a, b]) => {
    const pa = getProject(a);
    const pb = getProject(b);
    if (!pa || !pb) return null;
    return {
      x1: pa.stars[0],
      y1: pa.stars[1],
      x2: pb.stars[0],
      y2: pb.stars[1],
    };
  })
  .filter((e): e is { x1: number; y1: number; x2: number; y2: number } => e !== null);

// Magnitude → radius. Magnitude 1 is brightest.
function r(m: number): number {
  if (m <= 1) return 5.2;
  if (m <= 2) return 3.6;
  if (m <= 3) return 2.6;
  return 2;
}
---

<figure class="constellation" aria-hidden="true">
  <svg viewBox="0 0 1000 600" preserveAspectRatio="xMidYMid meet" role="presentation">
    <defs>
      <radialGradient id="star-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="currentColor" stop-opacity="0.9" />
        <stop offset="40%" stop-color="currentColor" stop-opacity="0.35" />
        <stop offset="100%" stop-color="currentColor" stop-opacity="0" />
      </radialGradient>
      <filter id="soft" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="0.6" />
      </filter>
    </defs>

    <g class="constellation__grid" aria-hidden="true">
      {Array.from({ length: 9 }).map((_, i) => (
        <line
          x1={0}
          x2={1000}
          y1={(i + 1) * 60}
          y2={(i + 1) * 60}
          stroke="currentColor"
          stroke-width="0.3"
          stroke-dasharray="2 6"
          opacity="0.08"
        />
      ))}
    </g>

    <g class="constellation__edges" stroke="currentColor" stroke-width="0.75" opacity="0.28">
      {edges.map((e) => (
        <line x1={e.x1} y1={e.y1} x2={e.x2} y2={e.y2} />
      ))}
    </g>

    <g class="constellation__stars">
      {projects.map((p, i) => (
        <g
          class="constellation__star"
          style={`--i: ${i}`}
          transform={`translate(${p.stars[0]} ${p.stars[1]})`}
          data-mag={p.magnitude}
        >
          <circle r={r(p.magnitude) * 4} fill="url(#star-glow)" opacity="0.4" />
          <circle r={r(p.magnitude)} fill="currentColor" filter="url(#soft)" />
          {p.magnitude === 1 && (
            <>
              <line
                x1={-r(p.magnitude) * 3}
                y1={0}
                x2={r(p.magnitude) * 3}
                y2={0}
                stroke="currentColor"
                stroke-width="0.4"
                opacity="0.5"
              />
              <line
                x1={0}
                y1={-r(p.magnitude) * 3}
                x2={0}
                y2={r(p.magnitude) * 3}
                stroke="currentColor"
                stroke-width="0.4"
                opacity="0.5"
              />
            </>
          )}
          <text
            class="constellation__label"
            x={r(p.magnitude) + 10}
            y={p.magnitude === 1 ? -r(p.magnitude) - 6 : 4}
            font-size={p.magnitude === 1 ? 14 : 10}
            fill="currentColor"
            opacity={p.magnitude === 1 ? 0.95 : 0.55}
          >
            {p.displayName}
          </text>
        </g>
      ))}
    </g>
  </svg>
</figure>
