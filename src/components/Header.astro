---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  current?: string;
}
const { current } = Astro.props as Props;

const nav = [
  { href: '/', label: 'Index', key: 'home' },
  { href: '/esse/', label: 'Esse', key: 'esse' },
  { href: '/lepus/', label: 'Lepus', key: 'lepus' },
  { href: '/site-maps/', label: 'SiteMaps', key: 'site-maps' },
];
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="brand" href="/" aria-label="marcosgz · projects">
      <span class="brand__dot" aria-hidden="true"></span>
      <span class="brand__mark">
        <span class="brand__first">marcosgz</span>
        <span class="brand__sep">/</span>
        <span class="brand__second">projects</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <ul>
        {nav.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={['site-nav__link', current === item.key && 'site-nav__link--current']}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="site-header__actions">
      <a
        class="site-header__gh"
        href="https://github.com/marcosgz"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub profile"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor">
          <path d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.11.8-.25.8-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.68 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18A11 11 0 0 1 12 6.6c.98 0 1.97.13 2.89.38 2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.24 2.76.12 3.05.73.81 1.18 1.84 1.18 3.1 0 4.41-2.69 5.39-5.25 5.67.41.36.77 1.07.77 2.16v3.2c0 .31.22.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z"/>
        </svg>
      </a>
      <ThemeToggle />
    </div>
  </div>
</header>
