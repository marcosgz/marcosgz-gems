---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import { projects } from '../../data/projects';

export async function getStaticPaths() {
  const all = await getCollection('docs');
  const validProjects = new Set(projects.map((p) => p.slug));

  return all
    .filter((entry) => validProjects.has(entry.data.project))
    .map((entry) => {
      const slug = entry.data.slug;
      // `index` renders at /<project>/  (caught by empty rest param)
      const rest = slug === 'index' ? undefined : slug;
      return {
        params: { project: entry.data.project, slug: rest },
        props: { entry },
      };
    });
}

interface Props {
  entry: CollectionEntry<'docs'>;
}
const { entry } = Astro.props as Props;
const { Content, headings } = await render(entry);
---

<DocsLayout
  project={entry.data.project}
  title={entry.data.title}
  slug={entry.data.slug}
  headings={headings}
>
  <Content />
</DocsLayout>
